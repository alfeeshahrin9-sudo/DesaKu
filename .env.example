# Copy to .env.local and fill in. .env.local is gitignored.

# Supabase — from your project's API settings (https://app.supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY. Bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Lightweight gate for the /admin area (MVP). Pick any strong string.
ADMIN_PASSCODE=change-me

# Signing key for the admin session cookie. Must be random and at least 16
# chars — without it the cookie could be forged and the admin area walked into.
# Generate one with:  openssl rand -hex 32
ADMIN_SESSION_SECRET=change-me-to-a-random-32-byte-hex-string

# Fonnte WhatsApp API — from fonnte.com → Account → Token
FONNTE_TOKEN=your-fonnte-token
